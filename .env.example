# Database (Supabase or Neon Postgres)
DATABASE_URL="postgresql://user:password@host:5432/tutmatch?schema=public"
DIRECT_URL="postgresql://user:password@host:5432/tutmatch?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-me-with-openssl-rand-base64-32"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_UNLOCK_PRICE_AUD_CENTS=2000

# Email (Resend)
RESEND_API_KEY="re_..."
EMAIL_FROM="hello@tutmatch.com.au"

# Storage (Supabase / S3) for ID, WWCC, HSC docs
STORAGE_BUCKET="tutmatch-verification"
STORAGE_REGION="ap-southeast-2"
STORAGE_ACCESS_KEY=""
STORAGE_SECRET_KEY=""

# App
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
ADMIN_EMAILS="founder@tutmatch.com.au"
