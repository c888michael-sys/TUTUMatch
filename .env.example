# Database (Supabase or Neon Postgres)
DATABASE_URL="postgresql://user:password@host:5432/tutumatch?schema=public"
DIRECT_URL="postgresql://user:password@host:5432/tutumatch?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-me-with-openssl-rand-base64-32"

# Stripe (test mode) — put the real values in .env.local, not here.
# Secret + publishable keys: Stripe Dashboard -> Developers -> API keys.
# Webhook secret: `stripe listen --forward-to localhost:3000/api/stripe/webhook`.
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# Commission charges are SIMULATED by default — no real Stripe call is made,
# so the match flow is testable without charges or a saved card. Only set this
# to "false" (with real keys above) when you're ready for real test-mode charges.
STRIPE_SIMULATE="true"

# Email (Resend)
RESEND_API_KEY="re_..."
EMAIL_FROM="hello@tutumatch.com.au"

# Storage (Supabase / S3) for ID, WWCC, HSC docs
STORAGE_BUCKET="tutumatch-verification"
STORAGE_REGION="ap-southeast-2"
STORAGE_ACCESS_KEY=""
STORAGE_SECRET_KEY=""

# App
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
ADMIN_EMAILS="founder@tutumatch.com.au"
